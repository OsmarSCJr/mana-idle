# URL base do Worker, sem barra final. Ex.: https://api.manaidle.com
VITE_API_URL=

# URL HTTPS do APK assinado. Deixe vazio enquanto o APK não estiver publicado.
VITE_DOWNLOAD_URL=

# E-mail público de privacidade/suporte. Vazio usa privacidade@manaidle.com;
# confirme uma caixa monitorada antes de publicar.
VITE_PRIVACY_EMAIL=
