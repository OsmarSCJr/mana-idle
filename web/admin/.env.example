# Apenas para `npm run dev`; no deploy, o browser usa /api no mesmo host.
VITE_ADMIN_API_URL=http://127.0.0.1:8787

# Segredo somente do processo Vite local. Nunca use prefixo VITE_ neste valor.
ADMIN_DEV_TOKEN=

# Opcional: URL explícita de login/reautenticação do Cloudflare Access.
VITE_ACCESS_LOGIN_URL=
